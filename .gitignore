# Ignore everything at the repo root by default; publish only the entries listed.
/*

# Published (the only things that leave this machine):
!/.gitignore
!/README.md
!/CLAUDE.md
!/AGENTS.md
!/index.md
!/homelab/

# Re-ignored inside the published folders (never publish these):
homelab/ansible/inventory/hosts.ini
homelab/ansible/inventory/group_vars/all.yml
homelab/ansible/inventory/host_vars/*.yml
homelab/terraform/.terraform/
homelab/terraform/*.tfstate
homelab/terraform/*.tfstate.*
homelab/terraform/terraform.tfvars
homelab/terraform/*.auto.tfvars
*.key
*.pem
*.p12
*.pfx
*.env
.env.*
vault_pass*
*_vault_password
secrets.yml
secrets.yaml
*credentials*
*token*
*.secret
id_rsa
id_ed25519
id_ecdsa
