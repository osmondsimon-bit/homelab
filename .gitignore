# Secrets — never commit these
*.key
*.pem
*.p12
*.pfx
*.env
.env.*
vault_pass*
vault-pass*
*_vault_password
secrets.yml
secrets.yaml
*credentials*
*token*
*.secret

# Ansible vault files (keep playbooks, not vault passwords)
.vault_pass
.vault-pass

# Local Ansible config — real IPs/hosts live here, never published.
# Copy the committed *.example templates and fill in your values (see ADR-006).
homelab/ansible/inventory/hosts.ini
homelab/ansible/inventory/group_vars/all.yml

# Private backup repo working dir (off-box backup of local-only config — ADR-007)
homelab-private/

# Terraform — state (can contain secrets) + real tfvars (API token). Keep *.example + lock file.
homelab/terraform/.terraform/
homelab/terraform/*.tfstate
homelab/terraform/*.tfstate.*
homelab/terraform/terraform.tfvars
homelab/terraform/*.auto.tfvars

# WireGuard
*.conf.bak
privatekey
publickey

# SSH private keys
id_rsa
id_ed25519
id_ecdsa
*_rsa
*_ed25519

# OS / shell noise
.DS_Store
Thumbs.db
.sudo_as_admin_successful
.bash_history
.bash_logout
.bashrc
.profile
.wget-hsts
.gitconfig

# SSH — keys and known hosts don't belong in the repo
.ssh/

# Claude Code internals
.claude/
.claude.json

# Editor / IDE
.vscode-server/
.config/

# Runtime / package caches
.cache/
.local/
.npm/
.dotnet/
