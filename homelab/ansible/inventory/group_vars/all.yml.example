---
# Non-secret defaults for homelab Ansible.
# Secrets (e.g. the Tailscale auth key) are prompted at runtime, never stored here.
# See decisions/005-activate-ansible.md.

# --- Proxmox / LXC general ---------------------------------------------------
rootfs_storage: local-zfs                                   # rootfs pool for new LXCs (all nodes are ZFS)
template_store: local                                       # where LXC templates live
lxc_template: debian-12-standard_12.12-1_amd64.tar.zst       # base template
bridge: vmbr0
gateway: YOUR_GATEWAY_IP

# --- Cold secondary management VM (Carter) ---------------------------------
# Independent Ubuntu control node, not a clone of VM 100. It is normally powered off;
# provision-secondary-mgmt.yml boots it only to converge/test, then shuts it down again.
secondary_mgmt_vmid: 128
secondary_mgmt_hostname: mgmt-vm2
secondary_mgmt_ram_mb: 8192
secondary_mgmt_cores: 2
secondary_mgmt_disk_gb: 64
secondary_mgmt_ip: YOUR_SECONDARY_MGMT_IP/24
secondary_mgmt_cpu: x86-64-v2-AES

# --- Tailscale LXC -----------------------------------------------------------
tailscale_ctid: 110                                         # ensure this VMID is free
tailscale_hostname: tailscale
tailscale_ram_mb: 256
tailscale_cores: 1
tailscale_disk_gb: 4
tailscale_ip: YOUR_TAILSCALE_LAN_IP/24                                # verify free; reserve in UniFi
tailscale_advertise_routes: "YOUR_LAN_CIDR"                # add IoT/mgmt subnets if wanted
# 2nd HA subnet router (CT 126) — removes the single remote-access chokepoint (one router node).
# Provisioned on a DIFFERENT node via per-instance overrides, then approve its route in the admin console:
#   ansible-playbook playbooks/provision-tailscale.yml --limit <node> \
#     -e tailscale_ctid=126 -e tailscale_ip=YOUR_TAILSCALE2_LAN_IP/24 -e tailscale_hostname=tailscale2
tailscale2_ip: YOUR_TAILSCALE2_LAN_IP/24                   # CT 126 — used by the Glance per-router health tile

# --- Technitium DNS LXC (DNS-only resolvers, ADR-011) ------------------------
# Shared shape + config (both resolvers stay identical). Per-instance identity is in
# technitium_instances below. technitium_ip = the PRIMARY (kept for the Glance tile +
# docs references).
technitium_hostname: technitium                            # primary hostname (back-compat refs)
technitium_ram_mb: 1024                                     # headroom for blocklists in memory
technitium_cores: 1
technitium_disk_gb: 4
technitium_startup: "order=1,up=15"                         # autostart ordering for the resolver CTs
technitium_ip: YOUR_TECHNITIUM_IP/24                        # PRIMARY; verify free; reserve in UniFi

# DNS redundancy: two resolvers on independent nodes — a single node loss never takes
# out DNS. Provisioned + kept config-identical by provision-technitium.yml. Put the 2nd
# on a DIFFERENT node than the 1st; hand BOTH out as DHCP DNS servers (primary+secondary).
technitium_instances:
  - { ctid: 111, hostname: technitium,  ip: YOUR_TECHNITIUM_IP/24,  node: oneill, rootfs_storage: local-zfs }
  - { ctid: 117, hostname: technitium2, ip: YOUR_TECHNITIUM2_IP/24, node: carter, rootfs_storage: local-zfs }

# Technitium config applied via API on every playbook run (declarative, ADR-011)
technitium_forwarders:                                      # encrypted upstreams
  - https://cloudflare-dns.com/dns-query
  - https://dns.quad9.net/dns-query
technitium_forwarder_protocol: Https                        # Udp | Tcp | Tls | Https | Quic
technitium_blocking_type: NxDomain                          # AnyAddress | NxDomain | CustomAddress
technitium_blocklist_update_hours: 24
technitium_blocklist_urls:                                  # ads/trackers/malware
  - https://big.oisd.nl/domainswild2

# --- Vaultwarden VM (self-hosted password manager — ADR-010/018; Phase 5) -----
# As-built 2026-06-26: official vaultwarden DOCKER container in a DEDICATED VM (Docker confined
# here — ADR-014 exception). Ubuntu 24.04 cloud image; container binds 127.0.0.1; Tailscale Serve
# does TLS (tailnet-only, NOT on the LAN). Replicated apophis->carter + PBS backup. Currently
# Codified in provision-vaultwarden.yml (manual recipe also in docs/operations/runbooks.md).
vaultwarden_vmid: 118
vaultwarden_hostname: vaultwarden
vaultwarden_ram_mb: 2048
vaultwarden_cores: 1
vaultwarden_disk_gb: 10
vaultwarden_ip: YOUR_VAULTWARDEN_IP/24                     # verify free; reserve in UniFi
vaultwarden_cpu: Skylake-Client-noTSX-IBRS                 # migratable across the Coffee-Lake pair (x86-64-v2-AES panics Debian cloud images)
vaultwarden_startup: "order=2,up=10"
# renovate: datasource=docker depName=vaultwarden/server
vaultwarden_image: vaultwarden/server:1.36.0              # PINNED container tag — Renovate proposes; operator deploys deliberately
vaultwarden_domain: https://vaultwarden.YOUR_TAILNET.ts.net # Tailscale Serve URL (tailnet-only) — Glance link-tile + Bitwarden server URL

# --- Actual Budget VM (personal finance, Carter; ADR-023) --------------------
# Dedicated Ubuntu VM: the official container stays isolated from the host and service LXCs.
# Actual binds to loopback; Tailscale Serve is the only ingress. Stateful /data is PBS-imaged.
actual_vmid: 127
actual_enabled: false                                      # set true only after VM 127 is live
actual_hostname: actual
actual_ram_mb: 2048
actual_cores: 1
actual_disk_gb: 10
actual_ip: YOUR_ACTUAL_IP/24                              # reserve in UniFi before provisioning
actual_mac: YOUR_ACTUAL_MAC                               # reserve this MAC+IP pair before provisioning
actual_cpu: Skylake-Client-noTSX-IBRS                     # live-migratable across the Coffee-Lake cluster pair
actual_startup: "order=5,up=10"
actual_ts_authkey_file: "{{ lookup('env', 'HOME') }}/.tailscale-actual-authkey" # one-use join key; chmod 600, never commit, delete after join
# renovate: datasource=docker depName=actualbudget/actual-server
actual_image: actualbudget/actual-server:26.7.0           # PINNED stable release; operator deploys deliberately
actual_domain: "{{ vaultwarden_domain | regex_replace('vaultwarden\\.', 'actual.') }}"

# --- Proxmox Backup Server LXC (backup hub on oneill, ADR-012) ---------------
# Unprivileged LXC; datastore on a quota'd ZFS dataset bind-mount. Run --limit oneill.
pbs_ctid: 112
pbs_hostname: pbs
pbs_ram_mb: 2048
pbs_cores: 2
pbs_disk_gb: 8
pbs_ip: YOUR_PBS_IP/24                                      # verify free; reserve in UniFi
pbs_datastore_dataset: rpool/data/pbs-datastore            # on the backup-hub node's ZFS pool
pbs_datastore_quota: 150G
pbs_datastore_mount: /mnt/datastore                         # bind-mount path inside the CT
pbs_datastore_name: main

# --- HA backup share LXC (Samba, unprivileged, on oneill — ADR-012) ----------
habackup_ctid: 113
habackup_hostname: ha-backup-share
habackup_ram_mb: 512
habackup_cores: 1
habackup_disk_gb: 4
habackup_ip: YOUR_HA_BACKUP_SHARE_IP/24                     # verify free; reserve in UniFi
habackup_dataset: rpool/data/ha-backup-share              # on the backup-hub node's ZFS pool
habackup_quota: 20G
habackup_mount: /srv/ha-backups                             # bind-mount path inside the CT
habackup_share_name: ha-backups                            # CIFS share name HAOS mounts
habackup_user: habackup                                     # Samba user HAOS authenticates as

# --- Monitoring LXC (Prometheus + Grafana, oneill — ADR-013) -----------------
monitoring_ctid: 114
monitoring_hostname: monitoring
monitoring_ram_mb: 3072
monitoring_cores: 2
monitoring_disk_gb: 8
monitoring_ip: YOUR_MONITORING_IP/24                        # verify free; reserve in UniFi
monitoring_tsdb_dataset: rpool/data/monitoring-tsdb        # on the monitoring node's ZFS pool
monitoring_tsdb_quota: 20G
monitoring_tsdb_mount: /var/lib/prometheus                  # bind-mount path (Prometheus data dir)
monitoring_retention_days: 30
monitoring_scrape_interval: 30s
backup_stale_max_age_seconds: 129600                        # 36h — BackupStale/freshness budget (ADR-017)
# Blackbox exporter (:9115) TCP-connect probe targets — black-box reachability of
# devices we can't scrape. SLZB-06 Zigbee coordinator: probing its Z2MQTT TCP port
# catches the coordinator dropping off-network (the root cause of Zigbee outages),
# independent of HA/Z2MQTT. Cross-VLAN (mgmt -> IoT): firewall must permit it.
zigbee_coordinator_target: "YOUR_ZIGBEE_COORD_IP:6638"     # SLZB-06 — Z2MQTT TCP port (6638)

# pve-exporter scrape targets (names MUST match inventory hostnames for token lookup)
monitoring_pve_nodes:
  - { name: apophis, host: YOUR_PROXMOX_IP }
  - { name: oneill, host: YOUR_NUC_IP }
  # clustered nodes SHARE one cluster-wide token (lives in shared /etc/pve); token_from
  # reuses that node's token instead of re-minting (avoids racing on the same token).
  - { name: carter, host: YOUR_CARTER_IP, token_from: apophis }

# UniFi (unpoller) + Home Assistant scrape targets (ADR-013). Passwords/tokens are
# entered at runtime (vars_prompt), never stored here.
unifi_controller_url: https://YOUR_GATEWAY_IP              # the UDM/gateway
unifi_user: prometheus_user                                # UniFi read-only local user
ha_ip: YOUR_HA_IP                                          # Home Assistant VM (scrape /api/prometheus)

# --- Alerting: ntfy (ADR-013) — topic is PRIVATE, treat as a secret ----------
ntfy_base_url: https://ntfy.sh
ntfy_topic: YOUR_NTFY_TOPIC                                 # pick a random topic; subscribe the ntfy app to it

# --- Alertmanager + am-ntfy bridge (ADR-013), both inside the monitoring CT ---
monitoring_alertmanager_port: 9093                          # Alertmanager web/API (localhost only)
monitoring_amntfy_port: 9095                                # webhook->ntfy bridge (localhost only; 9094 is AM's cluster port)

# --- Glance dashboard LXC (front-door, oneill — ADR-014) ---------------------
glance_ctid: 115
glance_hostname: glance
glance_ram_mb: 512
glance_cores: 1
glance_disk_gb: 4
glance_ip: YOUR_GLANCE_IP/24                                # verify free; reserve in UniFi
glance_port: 8080
glance_version: v0.8.5                                      # PINNED (pre-1.0 renames config keys; bump deliberately)
# Three-page operator dashboard rendered from templates/glance/glance.yml.j2 (ADR-014). Service-tile
# URLs are built from existing IP vars; placement metadata keeps the launcher grouped by host.
glance_prometheus_url: "http://YOUR_MONITORING_IP:9090"     # monitoring CT — custom-api widgets query Prometheus here
# Optional live Media-page insights. Enable only after placing the three API keys in the REAL,
# gitignored all.yml. They are installed as root-owned systemd credentials and used only for GETs;
# no poster/thumbnail URLs are rendered because those can expose tokens in browser-visible HTML.
glance_media_api_enabled: false
glance_media_jellyfin_api_key: ""                           # Jellyfin Dashboard -> API Keys
glance_media_sonarr_api_key: ""                             # Sonarr Settings -> General -> Security
glance_media_radarr_api_key: ""                             # Radarr Settings -> General -> Security
glance_hosts:                                               # Proxmox nodes — host CPU/RAM/updates panes + node links
  - { name: apophis, node_exporter_instance: "YOUR_PROXMOX_IP:9100", pve_instance: "YOUR_PROXMOX_IP" }
  - { name: oneill,  node_exporter_instance: "YOUR_NUC_IP:9100",     pve_instance: "YOUR_NUC_IP" }
  - { name: carter,  node_exporter_instance: "YOUR_CARTER_IP:9100",  pve_instance: "YOUR_CARTER_IP" }

# Glance "Service Status" tiles — ONE place to add a new service (ADR-017 onboarding).
# URLs reference the existing *_ip vars (IPs stay DRY); optional: check_url, allow_insecure,
# alt_status_codes (for endpoints that answer 401/403 when healthy).
glance_services:
  - { title: "Home Assistant", node: apophis, workload: "VM 200", url: "http://{{ ha_ip | regex_replace('/.*$','') }}:8123", icon: "di:home-assistant" }
  - { title: "Jellyfin", node: apophis, workload: "CT 120", url: "http://{{ jellyfin_ip | regex_replace('/.*$','') }}:{{ jellyfin_port }}", check_url: "http://{{ jellyfin_ip | regex_replace('/.*$','') }}:{{ jellyfin_port }}/System/Info/Public", icon: "di:jellyfin" }
  - { title: "qBittorrent", node: apophis, workload: "CT 121", url: "http://{{ qbittorrent_ip | regex_replace('/.*$','') }}:{{ qbittorrent_webui_port }}", icon: "di:qbittorrent" }
  - { title: "Prowlarr", node: apophis, workload: "VM 125", url: "http://{{ jellyseerr_ip | regex_replace('/.*$','') }}:{{ prowlarr_port }}", check_url: "http://{{ jellyseerr_ip | regex_replace('/.*$','') }}:{{ prowlarr_port }}/ping", icon: "di:prowlarr" }
  - { title: "Sonarr", node: apophis, workload: "CT 123", url: "http://{{ sonarr_ip | regex_replace('/.*$','') }}:{{ sonarr_port }}", check_url: "http://{{ sonarr_ip | regex_replace('/.*$','') }}:{{ sonarr_port }}/ping", icon: "di:sonarr" }
  - { title: "Radarr", node: apophis, workload: "CT 124", url: "http://{{ radarr_ip | regex_replace('/.*$','') }}:{{ radarr_port }}", check_url: "http://{{ radarr_ip | regex_replace('/.*$','') }}:{{ radarr_port }}/ping", icon: "di:radarr" }
  - { title: "Seerr", node: apophis, workload: "VM 125", url: "http://{{ jellyseerr_ip | regex_replace('/.*$','') }}:{{ jellyseerr_port }}", check_url: "http://{{ jellyseerr_ip | regex_replace('/.*$','') }}:{{ jellyseerr_port }}/api/v1/status", icon: "di:seerr" }
  - { title: "Technitium DNS", node: oneill, workload: "CT 111", url: "http://{{ technitium_instances[0].ip | regex_replace('/.*$','') }}:5380", icon: "di:technitium", alt_status_codes: [401, 403] }
  - { title: "Technitium DNS 2", node: carter, workload: "CT 117", url: "http://{{ technitium_instances[1].ip | regex_replace('/.*$','') }}:5380", icon: "di:technitium", alt_status_codes: [401, 403] }
  - { title: "Grafana", node: oneill, workload: "CT 114", url: "http://{{ monitoring_ip | regex_replace('/.*$','') }}:3000", check_url: "http://{{ monitoring_ip | regex_replace('/.*$','') }}:3000/api/health", icon: "di:grafana" }
  - { title: "Prometheus", node: oneill, workload: "CT 114", url: "http://{{ monitoring_ip | regex_replace('/.*$','') }}:9090", check_url: "http://{{ monitoring_ip | regex_replace('/.*$','') }}:9090/-/healthy", icon: "di:prometheus" }
  - { title: "Alertmanager", node: oneill, workload: "CT 114", url: "http://{{ monitoring_ip | regex_replace('/.*$','') }}:9093", check_url: "http://{{ monitoring_ip | regex_replace('/.*$','') }}:9093/-/healthy", icon: "di:alertmanager" }
  - { title: "Proxmox Backup Server", node: oneill, workload: "CT 112", url: "https://{{ pbs_ip | regex_replace('/.*$','') }}:8007", check_url: "https://{{ pbs_ip | regex_replace('/.*$','') }}:8007", icon: "di:proxmox-backup-server", allow_insecure: true, alt_status_codes: [401, 403] }
  # Tailscale HA subnet-router pair: tiles link to the admin console; the HEALTH check hits each
  # router CT's own :9099 endpoint (200 iff tailscaled up AND advertising the approved LAN route) —
  # REAL per-router status (a broken router shows RED even when Tailscale's cloud is fine). The
  # endpoint is deployed by provision-tailscale.yml. tailscale = router #1; tailscale2 = router #2 (HA).
  - { title: "Tailscale", node: apophis, workload: "CT 110", url: "https://login.tailscale.com/admin/machines", check_url: "http://{{ tailscale_ip | regex_replace('/.*$','') }}:9099/", icon: "di:tailscale" }
  - { title: "Tailscale2", node: oneill, workload: "CT 126", url: "https://login.tailscale.com/admin/machines", check_url: "http://{{ tailscale2_ip | regex_replace('/.*$','') }}:9099/", icon: "di:tailscale" }
  - { title: "Infra Portal", node: oneill, workload: "CT 116", url: "http://{{ portal_ip }}", icon: "si:blueprint" }

# Declared pins that can be compared directly with an upstream GitHub release tag.
glance_version_currency:
  - { key: glance, title: "Glance", configured: "{{ glance_version }}", repository: glanceapp/glance }
  - { key: vaultwarden, title: "Vaultwarden", configured: "{{ vaultwarden_image | regex_replace('^.*:', '') }}", repository: dani-garcia/vaultwarden }
  - { key: seerr, title: "Seerr", configured: "{{ seerr_image | regex_replace('^.*:', '') }}", repository: seerr-team/seerr }
  - { key: actual, title: "Actual Budget", configured: "{{ actual_image | regex_replace('^.*:', '') }}", repository: actualbudget/actual }

# Glance "Latest Releases" — bump when a new service has a GitHub release to track.
glance_release_repos:
  - glanceapp/glance
  - prometheus/prometheus
  - grafana/grafana
  - tailscale/tailscale
  - TechnitiumSoftware/DnsServer
  - terrastruct/d2
  - dani-garcia/vaultwarden
  - jellyfin/jellyfin
  - qbittorrent/qBittorrent
  - Prowlarr/Prowlarr
  - Sonarr/Sonarr
  - Radarr/Radarr
  - seerr-team/seerr
  - actualbudget/actual

# --- Infra Portal (CT 116, oneill — ADR-020) ---------------------
portal_ctid: 116
portal_hostname: infra-portal
portal_ram_mb: 256
portal_cores: 1
portal_disk_gb: 3
portal_ip: YOUR_PORTAL_IP                                   # reserve in UniFi before running provision-infra-portal.yml
d2_version: v0.6.9                                         # PINNED — bump deliberately (breaking changes in d2)

# --- Patching (ADR-015) — set to YOUR local tz so guest security upgrades fire at LOCAL noon ---
patching_timezone: "Etc/UTC"                                # set your IANA Region/City tz; blank/UTC = 12:00 UTC

# --- Media stack (Phase 6, ADR-021) — apophis; USB-C SSD at /mnt/usb-media ---
media_host_root: /mnt/usb-media                            # ext4 USB SSD on apophis (by-id, nofail); NOT backed up
media_owner_uid: 100000                                    # unprivileged-CT root host mapping (shared by CT 120/121/123/124)
media_owner_gid: 100000
media_group_gid_host: 101000                               # media group HOST gid (= in-CT gid 1000 via default unpriv map); owns the media tree (setgid 2775)
media_group_gid_ct: 1000                                   # media group in-container gid — jellyfin/qbit/sonarr/radarr users join it (umask 002)

# Jellyfin (CT 120, apophis — ADR-021): unprivileged LXC, iGPU /dev/dri passthrough (QuickSync)
jellyfin_ctid: 120
jellyfin_hostname: jellyfin
jellyfin_ram_mb: 2048
jellyfin_cores: 2
jellyfin_disk_gb: 16                                       # rootfs holds Jellyfin's transcode temp; 8G fills under load — see throttle task in provision-jellyfin.yml
jellyfin_ip: YOUR_JELLYFIN_IP/24                            # reserve in UniFi before running provision-jellyfin.yml
jellyfin_port: 8096
jellyfin_render_gid: 993                                   # host 'render' group GID (verify: getent group render)
jellyfin_card_devno: "226:0"                               # /dev/dri/card0 (video)      — verify: ls -l /dev/dri
jellyfin_render_devno: "226:128"                           # /dev/dri/renderD128 (render)

# qBittorrent (CT 121, apophis — ADR-021, Phase 6b): native WireGuard egress + nftables killswitch
qbittorrent_ctid: 121
qbittorrent_hostname: qbittorrent
qbittorrent_ram_mb: 2048
qbittorrent_cores: 2
qbittorrent_disk_gb: 8
qbittorrent_ip: YOUR_QBITTORRENT_IP/24                     # reserve in UniFi before running provision-qbittorrent.yml
qbittorrent_webui_port: 8080
lan_cidr: YOUR_LAN_CIDR                                     # your LAN /24 — hosts allowed to reach Web-UI / SSH
# Paste the ProtonVPN WireGuard config (P2P server, NAT-PMP ON) as a block scalar in the REAL all.yml.
# SECRET — never commit. Endpoint must be IP:port (Proton configs are). Example shape:
#   qbittorrent_wg_config: |
#     [Interface]
#     PrivateKey = <client-private-key>
#     Address = 10.0.0.2/32  (ProtonVPN tunnel addr, not a homelab address)  # scan-allow
#     DNS = 10.0.0.1  (ProtonVPN tunnel DNS)  # scan-allow
#     [Peer]
#     PublicKey = <server-public-key>
#     AllowedIPs = 0.0.0.0/0
#     Endpoint = 1.2.3.4:51820
qbittorrent_wg_config: ""

# --- Media automation (Phase 7, ADR-022) — apophis ------------------------------
# Prowlarr now runs behind a VPN on VM 125 (see the jellyseerr block); only its port remains here.
prowlarr_port: 9696                                         # Prowlarr WebUI — published on the VM 125 IP via Gluetun

sonarr_ctid: 123
sonarr_hostname: sonarr
sonarr_ram_mb: 1024
sonarr_cores: 1
sonarr_disk_gb: 8
sonarr_ip: YOUR_SONARR_IP/24
sonarr_port: 8989

radarr_ctid: 124
radarr_hostname: radarr
radarr_ram_mb: 1024
radarr_cores: 1
radarr_disk_gb: 8
radarr_ip: YOUR_RADARR_IP/24
radarr_port: 7878

# Jellyseerr = Docker VM (VMID 125, Ubuntu 24.04 — like Vaultwarden)
jellyseerr_vmid: 125
jellyseerr_hostname: jellyseerr
jellyseerr_ram_mb: 3072                                     # 3 GB: jellyseerr + gluetun + prowlarr + ByParr's headless browser
jellyseerr_cores: 2
jellyseerr_disk_gb: 20                                      # ByParr's browser-bundled image is large
jellyseerr_ip: YOUR_JELLYSEERR_IP/24
jellyseerr_cpu: Skylake-Client-noTSX-IBRS
jellyseerr_port: 5055
# renovate: datasource=docker depName=ghcr.io/seerr-team/seerr
seerr_image: "ghcr.io/seerr-team/seerr:v3.3.0"             # PIN — Renovate proposes; operator deploys deliberately
# Indexer VPN stack on VM 125 (Gluetun + Prowlarr behind it) — bypasses ISP blocks + consistent exit IP.
# Prowlarr WebUI published on the VM IP :{{ prowlarr_port }}. (ByParr/FlareSolverr added behind the same
# Gluetun later only if an indexer needs Cloudflare-solving.)
# renovate: datasource=docker depName=qmcgaw/gluetun currentValue=latest
gluetun_image: "qmcgaw/gluetun@sha256:d180743987bb24da1d749a1d7f3a78026e64ba2d09d2e08cc34b0acee7f7321b"   # PINNED by digest — Renovate proposes; operator deploys deliberately
# renovate: datasource=docker depName=lscr.io/linuxserver/prowlarr currentValue=latest
prowlarr_docker_image: "lscr.io/linuxserver/prowlarr@sha256:3950b5e48cf4ba9dab78fe14038dd7f062e66b7b4ab368b02c94a13f6a3dae9f"   # PINNED by digest — Renovate proposes; operator deploys deliberately
# renovate: datasource=docker depName=ghcr.io/thephaseless/byparr currentValue=latest
byparr_image: "ghcr.io/thephaseless/byparr@sha256:01a46a2865d9a6db5eb8ead04ec0dd33b8fbe233e8565ae70b50d4cc0af4cfb0"   # PINNED by digest — Renovate proposes; operator deploys deliberately
# Paste a 2nd ProtonVPN WireGuard config (any server, NO port-forwarding) in the REAL all.yml. SECRET.
prowlarr_vpn_wg_config: ""
