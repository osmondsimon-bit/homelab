[proxmox]
apophis ansible_host=YOUR_PROXMOX_IP ansible_user=root

[mgmt]
mgmt-vm ansible_host=YOUR_MGMT_VM_IP ansible_user=simon

# HAOS appliance (VMID 200). Note: Home Assistant OS is a managed appliance with
# no general-purpose Python/SSH environment, so most standard Ansible modules will
# NOT work against it. Manage it via the REST API / community.home_assistant
# collection, or SSH through the Advanced SSH & Web Terminal add-on.
[homeassistant]
home-assistant ansible_host=YOUR_HA_IP ansible_user=root

# Tailscale subnet-router LXC (CT 110 on apophis, advertises YOUR_LAN_CIDR).
# Managed via `pct exec` from the Proxmox host (playbooks/provision-tailscale.yml),
# not via direct SSH — listed here for reference/documentation.
[tailscale]
tailscale ansible_host=YOUR_TAILSCALE_LAN_IP ansible_user=root

[homelab:children]
proxmox
mgmt
homeassistant
tailscale
