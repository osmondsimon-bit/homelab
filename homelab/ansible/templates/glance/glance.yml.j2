#jinja2: variable_start_string:'<<', variable_end_string:'>>', block_start_string:'<%', block_end_string:'%>', trim_blocks:True, lstrip_blocks:True
# MANAGED BY ANSIBLE — provision-glance.yml renders this operator dashboard (ADR-014).
# Edit this template and the glance_* data in group_vars, then re-run the playbook. Do not edit
# the live file. Custom Jinja delimiters leave Glance's Go-template {{ }} expressions untouched.
# Real LAN values come from gitignored group_vars; committed examples remain placeholder-only.
<% set prom = glance_prometheus_url ~ '/api/v1/query' %>
<% set unifi = gateway | regex_replace('/.*$', '') %>
<% set glance_host_instances = glance_hosts | map(attribute='node_exporter_instance') | map('regex_escape') | join('|') %>
server:
  host: 0.0.0.0
  port: << glance_port >>
  assets-path: /etc/glance/assets

branding:
  app-name: "Homelab"
  logo-text: "HL"
  hide-footer: true

theme:
  background-color: 220 12 10
  primary-color: 173 58 52
  positive-color: 142 48 48
  negative-color: 4 70 58
  contrast-multiplier: 1.08
  custom-css-file: /assets/operator.css

pages:
  # Daily operator surface: concerns first on every viewport, then service launchers, then detail.
  - name: Overview
    width: wide
    head-widgets:
      - type: custom-api
        title: Operational Signals
        css-class: operator-summary
        cache: 1m
        url: << prom >>
        parameters:
          query: sum(ALERTS{alertstate="firing"})
        subrequests:
          targets:
            url: << prom >>
            parameters:
              query: sum(up == 0)
          backup_stale:
            url: << prom >>
            parameters:
              query: sum((time() - homelab_backup_last_success_timestamp_seconds) > bool homelab_backup_max_age_seconds)
          backup_total:
            url: << prom >>
            parameters:
              query: count(homelab_backup_last_success_timestamp_seconds)
          backup_fresh:
            url: << prom >>
            parameters:
              query: sum((time() - homelab_backup_last_success_timestamp_seconds) <= bool homelab_backup_max_age_seconds)
          security:
            url: << prom >>
            parameters:
              query: sum(homelab_apt_security_upgrades_pending)
          automatic_security:
            url: << prom >>
            parameters:
              query: sum(homelab_apt_security_upgrades_pending{kind=~"ubuntu-vm|lxc"})
          manual_security:
            url: << prom >>
            parameters:
              query: sum(homelab_apt_security_upgrades_pending{kind="pve-host"})
          security_overdue:
            url: << prom >>
            parameters:
              query: count(ALERTS{alertname="SecurityUpdatesPending",alertstate="firing"})
          routine:
            url: << prom >>
            parameters:
              query: sum(clamp_min(homelab_apt_upgrades_pending - ignoring(policy) homelab_apt_security_upgrades_pending, 0))
          reboot:
            url: << prom >>
            parameters:
              query: sum(homelab_reboot_required)
          audit_age:
            url: << prom >>
            parameters:
              query: max((time() - homelab_maintenance_last_check_timestamp_seconds) / 3600)
          local_storage:
            url: << prom >>
            parameters:
              query: 100 * max(pve_disk_usage_bytes{id=~"storage/.*/local-zfs"} / pve_disk_size_bytes{id=~"storage/.*/local-zfs"})
          pbs_storage:
            url: << prom >>
            parameters:
              query: 100 * max(pve_disk_usage_bytes{id=~"storage/.*/pbs-oneill"} / pve_disk_size_bytes{id=~"storage/.*/pbs-oneill"})
          host_cpu:
            url: << prom >>
            parameters:
              query: max(instance:node_cpu_util:percent{instance=~`<< glance_host_instances >>`})
          host_ram:
            url: << prom >>
            parameters:
              query: max(instance:node_mem_util:percent{instance=~`<< glance_host_instances >>`})
        template: |
          {{ $targets := .Subrequest "targets" }}
          {{ $backupStale := .Subrequest "backup_stale" }}
          {{ $backupTotal := .Subrequest "backup_total" }}
          {{ $backupFresh := .Subrequest "backup_fresh" }}
          {{ $security := .Subrequest "security" }}
          {{ $automaticSecurity := .Subrequest "automatic_security" }}
          {{ $manualSecurity := .Subrequest "manual_security" }}
          {{ $securityOverdue := .Subrequest "security_overdue" }}
          {{ $routine := .Subrequest "routine" }}
          {{ $reboot := .Subrequest "reboot" }}
          {{ $auditAgeResult := .Subrequest "audit_age" }}
          {{ $localStorage := .Subrequest "local_storage" }}
          {{ $pbsStorage := .Subrequest "pbs_storage" }}
          {{ $hostCPU := .Subrequest "host_cpu" }}
          {{ $hostRAM := .Subrequest "host_ram" }}
          {{ $alertsN := 0.0 }}{{ range .JSON.Array "data.result" }}{{ $alertsN = .Float "value.1" }}{{ end }}
          {{ $targetsN := 0.0 }}{{ range $targets.JSON.Array "data.result" }}{{ $targetsN = .Float "value.1" }}{{ end }}
          {{ $staleN := 0.0 }}{{ range $backupStale.JSON.Array "data.result" }}{{ $staleN = .Float "value.1" }}{{ end }}
          {{ $backupN := 0.0 }}{{ range $backupTotal.JSON.Array "data.result" }}{{ $backupN = .Float "value.1" }}{{ end }}
          {{ $freshN := 0.0 }}{{ range $backupFresh.JSON.Array "data.result" }}{{ $freshN = .Float "value.1" }}{{ end }}
          {{ $securityN := 0.0 }}{{ range $security.JSON.Array "data.result" }}{{ $securityN = .Float "value.1" }}{{ end }}
          {{ $automaticSecurityN := 0.0 }}{{ range $automaticSecurity.JSON.Array "data.result" }}{{ $automaticSecurityN = .Float "value.1" }}{{ end }}
          {{ $manualSecurityN := 0.0 }}{{ range $manualSecurity.JSON.Array "data.result" }}{{ $manualSecurityN = .Float "value.1" }}{{ end }}
          {{ $securityOverdueN := 0.0 }}{{ range $securityOverdue.JSON.Array "data.result" }}{{ $securityOverdueN = .Float "value.1" }}{{ end }}
          {{ $routineN := 0.0 }}{{ range $routine.JSON.Array "data.result" }}{{ $routineN = .Float "value.1" }}{{ end }}
          {{ $rebootN := 0.0 }}{{ range $reboot.JSON.Array "data.result" }}{{ $rebootN = .Float "value.1" }}{{ end }}
          {{ $auditAge := 0.0 }}{{ range $auditAgeResult.JSON.Array "data.result" }}{{ $auditAge = .Float "value.1" }}{{ end }}
          {{ $storageMax := 0.0 }}
          {{ range $localStorage.JSON.Array "data.result" }}{{ if gt (.Float "value.1") $storageMax }}{{ $storageMax = .Float "value.1" }}{{ end }}{{ end }}
          {{ range $pbsStorage.JSON.Array "data.result" }}{{ if gt (.Float "value.1") $storageMax }}{{ $storageMax = .Float "value.1" }}{{ end }}{{ end }}
          {{ $cpuMax := 0.0 }}{{ range $hostCPU.JSON.Array "data.result" }}{{ $cpuMax = .Float "value.1" }}{{ end }}
          {{ $ramMax := 0.0 }}{{ range $hostRAM.JSON.Array "data.result" }}{{ $ramMax = .Float "value.1" }}{{ end }}
          {{ $hasAudit := gt (len ($auditAgeResult.JSON.Array "data.result")) 0 }}
          {{ $attention := or (gt $alertsN 0.0) (gt $targetsN 0.0) (gt $staleN 0.0) (eq $backupN 0.0) (gt $securityOverdueN 0.0) (gt $rebootN 0.0) (not $hasAudit) (ge $storageMax 85.0) (ge $cpuMax 90.0) (ge $ramMax 90.0) }}
          <div class="signal-grid">
            <div class="signal-card">
              <div class="signal-label">Core telemetry</div>
              <div class="signal-value {{ if $attention }}color-negative{{ else }}color-positive{{ end }}">{{ if $attention }}Attention{{ else }}Healthy{{ end }}</div>
              <div class="signal-detail">Native service checks remain below</div>
            </div>
            <div class="signal-card">
              <div class="signal-label">Monitoring</div>
              <div class="signal-value {{ if or (gt $alertsN 0.0) (gt $targetsN 0.0) }}color-negative{{ else }}color-positive{{ end }}">{{ printf "%.0f alerts" $alertsN }}</div>
              <div class="signal-detail">{{ printf "%.0f failed scrape targets" $targetsN }}</div>
            </div>
            <div class="signal-card">
              <div class="signal-label">Backups</div>
              <div class="signal-value {{ if or (gt $staleN 0.0) (eq $backupN 0.0) }}color-negative{{ else }}color-positive{{ end }}">{{ printf "%.0f / %.0f fresh" $freshN $backupN }}</div>
              <div class="signal-detail">{{ printf "%.0f outside freshness budget" $staleN }}</div>
            </div>
            <div class="signal-card">
              <div class="signal-label">Maintenance</div>
              <div class="signal-value {{ if or (gt $securityOverdueN 0.0) (gt $rebootN 0.0) (not $hasAudit) }}color-negative{{ else if or (gt $manualSecurityN 0.0) (gt $routineN 0.0) }}color-highlight{{ else }}color-positive{{ end }}">{{ if not $hasAudit }}Audit stale{{ else if gt $rebootN 0.0 }}{{ printf "%.0f reboots" $rebootN }}{{ else if gt $securityOverdueN 0.0 }}{{ printf "%.0f security overdue" $securityN }}{{ else if gt $routineN 0.0 }}{{ printf "%.0f routine monthly" $routineN }}{{ else if gt $manualSecurityN 0.0 }}{{ printf "%.0f security monthly" $manualSecurityN }}{{ else if gt $securityN 0.0 }}{{ printf "%.0f security automatic" $securityN }}{{ else }}Clear{{ end }}</div>
              <div class="signal-detail">{{ printf "%.0f automatic · %.0f manual · %.0f routine monthly" $automaticSecurityN $manualSecurityN $routineN }}</div>
            </div>
            <div class="signal-card">
              <div class="signal-label">Resource pressure</div>
              <div class="signal-value {{ if or (ge $storageMax 85.0) (ge $cpuMax 90.0) (ge $ramMax 90.0) }}color-negative{{ else if or (ge $storageMax 70.0) (ge $cpuMax 75.0) (ge $ramMax 75.0) }}color-highlight{{ else }}color-positive{{ end }}">{{ printf "%.0f%% max RAM" $ramMax }}</div>
              <div class="signal-detail">{{ printf "CPU %.0f%% · storage %.0f%%" $cpuMax $storageMax }}</div>
            </div>
          </div>

    columns:
      - size: full
        widgets:
          - type: custom-api
            title: Host Pulse
            css-class: host-pulse
            cache: 30s
            url: << prom >>
            parameters:
              query: instance:node_cpu_util:percent{instance=~`<< glance_host_instances >>`}
            subrequests:
              ram:
                url: << prom >>
                parameters:
                  query: instance:node_mem_util:percent{instance=~`<< glance_host_instances >>`}
              storage:
                url: << prom >>
                parameters:
                  query: 100 * max by(node) (label_replace(pve_disk_usage_bytes{id=~"storage/.*/local-zfs"} / pve_disk_size_bytes{id=~"storage/.*/local-zfs"}, "node", "$1", "id", "storage/([^/]+)/local-zfs"))
              storage_used:
                url: << prom >>
                parameters:
                  query: max by(node) (label_replace(pve_disk_usage_bytes{id=~"storage/.*/local-zfs"} / 1e9, "node", "$1", "id", "storage/([^/]+)/local-zfs"))
              storage_size:
                url: << prom >>
                parameters:
                  query: max by(node) (label_replace(pve_disk_size_bytes{id=~"storage/.*/local-zfs"} / 1e9, "node", "$1", "id", "storage/([^/]+)/local-zfs"))
              pbs_percent:
                url: << prom >>
                parameters:
                  query: 100 * max(pve_disk_usage_bytes{id=~"storage/.*/pbs-oneill"} / pve_disk_size_bytes{id=~"storage/.*/pbs-oneill"})
              pbs_used:
                url: << prom >>
                parameters:
                  query: max(pve_disk_usage_bytes{id=~"storage/.*/pbs-oneill"}) / 1e9
              pbs_size:
                url: << prom >>
                parameters:
                  query: max(pve_disk_size_bytes{id=~"storage/.*/pbs-oneill"}) / 1e9
              media_mounted:
                url: << prom >>
                parameters:
                  query: node_systemd_unit_state{job="node",node="apophis",name="mnt-usb\\x2dmedia.mount",state="active"}
              media_up:
                url: << prom >>
                parameters:
                  query: up{job="node",node="apophis"}
              media_used:
                url: << prom >>
                parameters:
                  query: homelab_media_storage_used_bytes{node="apophis"} / 1e9
              media_size:
                url: << prom >>
                parameters:
                  query: homelab_media_storage_size_bytes{node="apophis"} / 1e9
              media_percent:
                url: << prom >>
                parameters:
                  query: 100 * homelab_media_storage_used_bytes{node="apophis"} / homelab_media_storage_size_bytes{node="apophis"}
              media_sample_age:
                url: << prom >>
                parameters:
                  query: (time() - homelab_media_storage_last_check_timestamp_seconds{node="apophis"}) / 3600
              updates:
                url: << prom >>
                parameters:
                  query: clamp_min(homelab_apt_upgrades_pending{kind="pve-host"} - ignoring(policy) homelab_apt_security_upgrades_pending{kind="pve-host"}, 0)
              security:
                url: << prom >>
                parameters:
                  query: homelab_apt_security_upgrades_pending{kind="pve-host"}
              reboot:
                url: << prom >>
                parameters:
                  query: homelab_reboot_required{kind="pve-host"}
            template: |
              {{ $ramResult := .Subrequest "ram" }}{{ $storage := .Subrequest "storage" }}{{ $storageUsed := .Subrequest "storage_used" }}{{ $storageSize := .Subrequest "storage_size" }}
              {{ $pbsPercent := .Subrequest "pbs_percent" }}{{ $pbsUsed := .Subrequest "pbs_used" }}{{ $pbsSize := .Subrequest "pbs_size" }}
              {{ $mediaMounted := .Subrequest "media_mounted" }}{{ $mediaUp := .Subrequest "media_up" }}{{ $mediaUsed := .Subrequest "media_used" }}{{ $mediaSize := .Subrequest "media_size" }}{{ $mediaPercent := .Subrequest "media_percent" }}{{ $mediaSampleAge := .Subrequest "media_sample_age" }}
              {{ $updates := .Subrequest "updates" }}{{ $security := .Subrequest "security" }}{{ $reboot := .Subrequest "reboot" }}
              <div class="host-pulse-grid">
              <% for h in glance_hosts %>
                {{ $hasTelemetry := false }}{{ $cpu := 0.0 }}{{ range $.JSON.Array "data.result" }}{{ if eq (.String "metric.instance") "<< h.node_exporter_instance >>" }}{{ $cpu = .Float "value.1" }}{{ $hasTelemetry = true }}{{ end }}{{ end }}
                {{ $ram := 0.0 }}{{ range $ramResult.JSON.Array "data.result" }}{{ if eq (.String "metric.instance") "<< h.node_exporter_instance >>" }}{{ $ram = .Float "value.1" }}{{ end }}{{ end }}
                {{ $disk := 0.0 }}{{ range $storage.JSON.Array "data.result" }}{{ if eq (.String "metric.node") "<< h.name >>" }}{{ $disk = .Float "value.1" }}{{ end }}{{ end }}
                {{ $diskUsed := 0.0 }}{{ range $storageUsed.JSON.Array "data.result" }}{{ if eq (.String "metric.node") "<< h.name >>" }}{{ $diskUsed = .Float "value.1" }}{{ end }}{{ end }}
                {{ $diskSize := 0.0 }}{{ range $storageSize.JSON.Array "data.result" }}{{ if eq (.String "metric.node") "<< h.name >>" }}{{ $diskSize = .Float "value.1" }}{{ end }}{{ end }}
                {{ $pending := 0.0 }}{{ range $updates.JSON.Array "data.result" }}{{ if eq (.String "metric.target") "<< h.name >>" }}{{ $pending = .Float "value.1" }}{{ end }}{{ end }}
                {{ $securityN := 0.0 }}{{ range $security.JSON.Array "data.result" }}{{ if eq (.String "metric.target") "<< h.name >>" }}{{ $securityN = .Float "value.1" }}{{ end }}{{ end }}
                {{ $rebootN := 0.0 }}{{ range $reboot.JSON.Array "data.result" }}{{ if eq (.String "metric.target") "<< h.name >>" }}{{ $rebootN = .Float "value.1" }}{{ end }}{{ end }}
                {{ $critical := or (ge $cpu 90.0) (ge $ram 90.0) (ge $disk 85.0) (gt $securityN 0.0) (gt $rebootN 0.0) }}
                {{ $warning := or (ge $cpu 75.0) (ge $ram 75.0) (ge $disk 70.0) }}
                <div class="host-pulse-card">
                  <div class="host-pulse-heading"><a class="color-highlight" href="https://<< h.pve_instance >>:8006" target="_blank" rel="noreferrer"><< h.name >></a><span class="{{ if not $hasTelemetry }}color-negative{{ else if $critical }}color-negative{{ else if $warning }}color-highlight{{ else }}color-positive{{ end }}">{{ if not $hasTelemetry }}No telemetry{{ else if $critical }}Attention{{ else if $warning }}Watch{{ else }}Healthy{{ end }}</span></div>
                  {{ if $hasTelemetry }}
                  <div class="host-pulse-metrics">
                    <div><div class="host-pulse-reading"><span>CPU</span><span>{{ printf "%.0f%%" $cpu }}</span></div><meter class="resource-meter {{ if ge $cpu 90.0 }}is-critical{{ else if ge $cpu 75.0 }}is-warning{{ end }}" min="0" max="100" low="75" high="90" optimum="0" value="{{ $cpu }}"></meter></div>
                    <div><div class="host-pulse-reading"><span>RAM</span><span>{{ printf "%.0f%%" $ram }}</span></div><meter class="resource-meter {{ if ge $ram 90.0 }}is-critical{{ else if ge $ram 75.0 }}is-warning{{ end }}" min="0" max="100" low="75" high="90" optimum="0" value="{{ $ram }}"></meter></div>
                    <div><div class="host-pulse-reading"><span>ZFS</span><span>{{ printf "%.0f%%" $disk }}</span></div><meter class="resource-meter {{ if ge $disk 85.0 }}is-critical{{ else if ge $disk 70.0 }}is-warning{{ end }}" min="0" max="100" low="70" high="85" optimum="0" value="{{ $disk }}"></meter><div class="host-pulse-capacity">{{ printf "%.0f / %.0f GB" $diskUsed $diskSize }}</div></div>
                  </div>
                  <div class="host-pulse-maintenance">{{ printf "%.0f monthly · %.0f security manual" $pending $securityN }}{{ if gt $rebootN 0.0 }} · reboot required{{ else }} · no reboot{{ end }}</div>
                  {{ else }}<div class="host-pulse-maintenance">Prometheus host series unavailable</div>{{ end }}
                </div>
              <% endfor %>
              </div>
              <div class="host-pulse-storage-grid">
              {{ range $pbsPercent.JSON.Array "data.result" }}{{ $value := .Float "value.1" }}
                <div class="host-pulse-storage-card"><div class="resource-heading"><div><div class="color-highlight">PBS datastore</div><div class="resource-label">Shared backup · shown once</div></div><div>{{ printf "%.0f%%" $value }}</div></div><meter class="resource-meter {{ if ge $value 85.0 }}is-critical{{ else if ge $value 70.0 }}is-warning{{ end }}" min="0" max="100" low="70" high="85" optimum="0" value="{{ $value }}"></meter><div class="resource-reading"><span>{{ range $pbsUsed.JSON.Array "data.result" }}{{ printf "%.0f GB used" (.Float "value.1") }}{{ end }}</span><span>{{ range $pbsSize.JSON.Array "data.result" }}{{ printf "%.0f GB total" (.Float "value.1") }}{{ end }}</span></div></div>
              {{ end }}
              {{ $mediaUpN := 0.0 }}{{ range $mediaUp.JSON.Array "data.result" }}{{ $mediaUpN = .Float "value.1" }}{{ end }}{{ $mediaMountedN := 0.0 }}{{ range $mediaMounted.JSON.Array "data.result" }}{{ $mediaMountedN = .Float "value.1" }}{{ end }}{{ if eq $mediaUpN 0.0 }}
                <div class="host-pulse-storage-card"><div class="resource-heading"><div><div class="color-highlight">Media USB</div><div class="resource-label">apophis · /mnt/usb-media</div></div><div class="color-negative">Monitoring unavailable</div></div><div class="resource-reading"><span>Apophis node_exporter unavailable</span><span>Check host and exporter</span></div></div>
              {{ else if eq $mediaMountedN 0.0 }}
                <div class="host-pulse-storage-card"><div class="resource-heading"><div><div class="color-highlight">Media USB</div><div class="resource-label">apophis · /mnt/usb-media</div></div><div class="color-negative">Not mounted</div></div><div class="resource-reading"><span>Capacity intentionally suppressed</span><span>Check USB device and mount</span></div></div>
              {{ else if eq (len ($mediaSize.JSON.Array "data.result")) 0 }}
                <div class="host-pulse-storage-card"><div class="resource-heading"><div><div class="color-highlight">Media USB</div><div class="resource-label">apophis · /mnt/usb-media</div></div><div class="color-positive">Mounted</div></div><div class="resource-reading"><span>Capacity sample pending</span><span>Six-hour cached collector</span></div></div>
              {{ else }}
                {{ $mediaUsedN := 0.0 }}{{ range $mediaUsed.JSON.Array "data.result" }}{{ $mediaUsedN = .Float "value.1" }}{{ end }}{{ $mediaSizeN := 0.0 }}{{ range $mediaSize.JSON.Array "data.result" }}{{ $mediaSizeN = .Float "value.1" }}{{ end }}{{ $mediaAgeN := 0.0 }}{{ range $mediaSampleAge.JSON.Array "data.result" }}{{ $mediaAgeN = .Float "value.1" }}{{ end }}{{ $mediaPercentN := 0.0 }}{{ range $mediaPercent.JSON.Array "data.result" }}{{ $mediaPercentN = .Float "value.1" }}{{ end }}
                <div class="host-pulse-storage-card"><div class="resource-heading"><div><div class="color-highlight">Media USB</div><div class="resource-label">apophis · /mnt/usb-media</div></div><div class="{{ if ge $mediaPercentN 85.0 }}color-negative{{ else if ge $mediaPercentN 70.0 }}color-highlight{{ else }}color-positive{{ end }}">{{ printf "%.0f%%" $mediaPercentN }}</div></div><meter class="resource-meter {{ if ge $mediaPercentN 85.0 }}is-critical{{ else if ge $mediaPercentN 70.0 }}is-warning{{ end }}" min="0" max="100" low="70" high="85" optimum="0" value="{{ $mediaPercentN }}"></meter><div class="resource-reading"><span>{{ printf "%.0f / %.0f GB" $mediaUsedN $mediaSizeN }}</span><span>{{ printf "sampled %.0fh ago" $mediaAgeN }}</span></div></div>
              {{ end }}
              </div>

          - type: split-column
            title: Service Directory
            css-class: service-directory
            max-columns: 3
            widgets:
              <% for h in glance_hosts %>
              - type: monitor
                title: << h.name >>
                cache: 1m
                sites:
                  <% for s in glance_services if s.node == h.name %>
                  - title: << s.title >> · << s.workload >>
                    url: << s.url >>
                  <% if s.check_url is defined %>
                    check-url: << s.check_url >>
                  <% endif %>
                    icon: << s.icon >>
                  <% if s.allow_insecure | default(false) %>
                    allow-insecure: true
                  <% endif %>
                  <% if s.alt_status_codes is defined %>
                    alt-status-codes: << s.alt_status_codes >>
                  <% endif %>
                  <% endfor %>
              <% endfor %>

          - type: monitor
            title: Core Infrastructure
            cache: 1m
            sites:
              <% for h in glance_hosts %>
              - title: Proxmox << h.name >>
                url: https://<< h.pve_instance >>:8006
                check-url: https://<< h.pve_instance >>:8006
                icon: di:proxmox
                allow-insecure: true
                alt-status-codes: [401, 403]
              <% endfor %>
              - title: UniFi
                url: https://<< unifi >>
                check-url: https://<< unifi >>
                icon: di:unifi
                allow-insecure: true
                alt-status-codes: [401, 403]

      - size: small
        widgets:
          - type: custom-api
            title: Maintenance State
            cache: 5m
            url: << prom >>
            parameters:
              query: sort_desc(clamp_min(homelab_apt_upgrades_pending{kind!="lxc"} - ignoring(policy) homelab_apt_security_upgrades_pending{kind!="lxc"}, 0))
            subrequests:
              security:
                url: << prom >>
                parameters:
                  query: homelab_apt_security_upgrades_pending{kind!="lxc"}
              reboot:
                url: << prom >>
                parameters:
                  query: homelab_reboot_required{kind!="lxc"}
              security_overdue:
                url: << prom >>
                parameters:
                  query: ALERTS{alertname="SecurityUpdatesPending",alertstate="firing",kind!="lxc"}
              patch_age:
                url: << prom >>
                parameters:
                  query: (time() - homelab_patch_last_success_timestamp_seconds{kind!="lxc"}) / 86400
              lxc_missing:
                url: << prom >>
                parameters:
                  query: sum(1 - homelab_patch_enrolled{kind="lxc"})
              lxc_total:
                url: << prom >>
                parameters:
                  query: count(homelab_patch_enrolled{kind="lxc"})
              lxc_security:
                url: << prom >>
                parameters:
                  query: sum(homelab_apt_security_upgrades_pending{kind="lxc"})
              lxc_pending:
                url: << prom >>
                parameters:
                  query: sum(clamp_min(homelab_apt_upgrades_pending{kind="lxc"} - ignoring(policy) homelab_apt_security_upgrades_pending{kind="lxc"}, 0))
            template: |
              {{ $security := .Subrequest "security" }}
              {{ $reboot := .Subrequest "reboot" }}
              {{ $securityOverdue := .Subrequest "security_overdue" }}
              {{ $patchAge := .Subrequest "patch_age" }}
              {{ $lxcMissing := .Subrequest "lxc_missing" }}
              {{ $lxcTotal := .Subrequest "lxc_total" }}
              {{ $lxcSecurity := .Subrequest "lxc_security" }}
              {{ $lxcPending := .Subrequest "lxc_pending" }}
              <div class="list list-gap-12 collapsible-container" data-collapse-after="6">
              {{ if eq (len (.JSON.Array "data.result")) 0 }}<div class="color-negative">No maintenance metrics</div>{{ end }}
              {{ range .JSON.Array "data.result" }}
                {{ $target := .String "metric.target" }}
                {{ $routineN := .Float "value.1" }}
                {{ $policy := .String "metric.policy" }}
                {{ $securityN := 0.0 }}{{ range $security.JSON.Array "data.result" }}{{ if eq (.String "metric.target") $target }}{{ $securityN = .Float "value.1" }}{{ end }}{{ end }}
                {{ $rebootN := 0.0 }}{{ range $reboot.JSON.Array "data.result" }}{{ if eq (.String "metric.target") $target }}{{ $rebootN = .Float "value.1" }}{{ end }}{{ end }}
                {{ $securityOverdueN := 0.0 }}{{ range $securityOverdue.JSON.Array "data.result" }}{{ if eq (.String "metric.target") $target }}{{ $securityOverdueN = .Float "value.1" }}{{ end }}{{ end }}
                <div>
                  <div class="flex justify-between gap-10"><div class="color-highlight">{{ $target }}</div>{{ if gt $rebootN 0.0 }}<div class="color-negative">Action required: reboot</div>{{ else if gt $securityOverdueN 0.0 }}<div class="color-negative">Action required: patch overdue</div>{{ else if or (gt $routineN 0.0) (and (eq $policy "manual-monthly") (gt $securityN 0.0)) }}<div class="color-highlight">Monthly action</div>{{ else if gt $securityN 0.0 }}<div class="color-positive">Automatic at daily patch window</div>{{ else }}<div class="color-positive">No action</div>{{ end }}</div>
                  <div class="size-h6 color-subdue">{{ if eq $policy "auto-security-manual-other" }}{{ printf "%.0f security automatic · %.0f routine monthly" $securityN $routineN }}{{ else }}{{ printf "%.0f security · %.0f routine · manual monthly" $securityN $routineN }}{{ end }} · {{ range $patchAge.JSON.Array "data.result" }}{{ if eq (.String "metric.target") $target }}{{ printf "last package change %.0fd ago" (.Float "value.1") }}{{ end }}{{ end }}</div>
                </div>
              {{ end }}
              <div>
                {{ $lxcMissingN := 0.0 }}{{ range $lxcMissing.JSON.Array "data.result" }}{{ $lxcMissingN = .Float "value.1" }}{{ end }}{{ $lxcTotalN := 0.0 }}{{ range $lxcTotal.JSON.Array "data.result" }}{{ $lxcTotalN = .Float "value.1" }}{{ end }}{{ $lxcRoutineN := 0.0 }}{{ range $lxcPending.JSON.Array "data.result" }}{{ $lxcRoutineN = .Float "value.1" }}{{ end }}{{ $lxcSecurityN := 0.0 }}{{ range $lxcSecurity.JSON.Array "data.result" }}{{ $lxcSecurityN = .Float "value.1" }}{{ end }}
                <div class="flex justify-between gap-10"><div class="color-highlight">Guest LXCs</div>{{ if gt $lxcMissingN 0.0 }}<div class="color-negative">Action required: enroll</div>{{ else if gt $lxcRoutineN 0.0 }}<div class="color-highlight">Monthly action</div>{{ else if gt $lxcSecurityN 0.0 }}<div class="color-positive">Automatic at daily patch window</div>{{ else }}<div class="color-positive">No action</div>{{ end }}</div>
                <div class="size-h6 color-subdue">{{ printf "%.0f security automatic · %.0f routine monthly" $lxcSecurityN $lxcRoutineN }} · {{ printf "%.0f total · %.0f missing" $lxcTotalN $lxcMissingN }}</div>
              </div>
              </div>

          - type: custom-api
            title: Backup State
            cache: 1m
            url: << prom >>
            parameters:
              query: label_replace(label_replace((time() - homelab_backup_last_success_timestamp_seconds) / 3600, "pveid", "qemu/$1", "group", "vm/(.+)"), "pveid", "lxc/$1", "group", "ct/(.+)")
            subrequests:
              budget:
                url: << prom >>
                parameters:
                  query: homelab_backup_max_age_seconds / 3600
              count:
                url: << prom >>
                parameters:
                  query: homelab_backup_count
              guests:
                url: << prom >>
                parameters:
                  query: pve_guest_info
            template: |
              {{ $budget := .Subrequest "budget" }}
              {{ $count := .Subrequest "count" }}
              {{ $guests := .Subrequest "guests" }}
              <div class="list list-gap-10">
              {{ if eq (len (.JSON.Array "data.result")) 0 }}<div class="color-negative">No backup metrics</div>{{ end }}
              {{ range .JSON.Array "data.result" }}
                {{ $type := .String "metric.type" }}{{ $group := .String "metric.group" }}{{ $pveid := .String "metric.pveid" }}{{ $age := .Float "value.1" }}{{ $budgetH := 0.0 }}
                {{ range $budget.JSON.Array "data.result" }}{{ if and (eq (.String "metric.type") $type) (eq (.String "metric.group") $group) }}{{ $budgetH = .Float "value.1" }}{{ end }}{{ end }}
                {{ $label := $group }}{{ if ne $pveid "" }}{{ range $guests.JSON.Array "data.result" }}{{ if eq (.String "metric.id") $pveid }}{{ $label = .String "metric.name" }}{{ end }}{{ end }}{{ end }}
                <div><div class="flex justify-between gap-10"><div class="color-highlight text-truncate">{{ $label }}</div><div class="{{ if gt $age $budgetH }}color-negative{{ else }}color-positive{{ end }}">{{ printf "%.1fh ago" $age }}</div></div><div class="size-h6 color-subdue">{{ if eq $type "pbs" }}PBS image{{ else if eq $type "ha" }}HA partial{{ else }}{{ $type }}{{ end }} · {{ range $count.JSON.Array "data.result" }}{{ if and (eq (.String "metric.type") $type) (eq (.String "metric.group") $group) }}{{ printf "%.0f kept" (.Float "value.1") }}{{ end }}{{ end }}</div></div>
              {{ end }}
              </div>

          - type: custom-api
            title: Update Review
            css-class: update-review
            title-url: https://github.com/osmondsimon-bit/homelab/issues?q=is%3Aissue%20is%3Aopen%20%22Dependency%20Dashboard%22
            cache: 12h
            url: https://api.github.com/repos/<< glance_version_currency[0].repository >>/releases/latest
            headers:
              Accept: application/vnd.github+json
              User-Agent: homelab-glance-dashboard
              X-GitHub-Api-Version: 2022-11-28
            subrequests:
              <% for c in glance_version_currency[1:] %>
              << c.key >>:
                url: https://api.github.com/repos/<< c.repository >>/releases/latest
                headers:
                  Accept: application/vnd.github+json
                  User-Agent: homelab-glance-dashboard
                  X-GitHub-Api-Version: 2022-11-28
              <% endfor %>
            template: |
              <% for c in glance_version_currency %>
              <% if loop.first %>
              {{ $latest_<< c.key >> := .JSON.String "tag_name" }}
              <% else %>
              {{ $response_<< c.key >> := .Subrequest "<< c.key >>" }}
              {{ $latest_<< c.key >> := $response_<< c.key >>.JSON.String "tag_name" }}
              <% endif %>
              {{ $current_<< c.key >> := or (eq $latest_<< c.key >> "<< c.configured >>") (eq $latest_<< c.key >> "v<< c.configured | regex_replace('^v', '') >>") }}
              <% endfor %>
              {{ $currencyAvailable := true }}{{ $hasUpdates := false }}
              <% for c in glance_version_currency %>
              {{ if eq $latest_<< c.key >> "" }}{{ $currencyAvailable = false }}{{ end }}{{ if not $current_<< c.key >> }}{{ $hasUpdates = true }}{{ end }}
              <% endfor %>
              {{ if $currencyAvailable }}
                {{ if $hasUpdates }}<div class="currency-grid">
                <% for c in glance_version_currency %>
                  {{ if not $current_<< c.key >> }}<div class="currency-row"><div><div class="color-highlight"><< c.title >></div><div class="size-h6 color-subdue">configured << c.configured >> · latest {{ $latest_<< c.key >> }}</div></div><div class="color-highlight">Review</div></div>{{ end }}
                <% endfor %>
                </div>{{ else }}<div class="color-subdue">No application updates to review</div>{{ end }}
              {{ else }}
                <div class="currency-unavailable"><span class="color-subdue">Release checks temporarily unavailable</span><span>Configured pins remain authoritative; Glance will retry.</span></div>
              {{ end }}

          - type: bookmarks
            title: Admin Links
            groups:
              - title: Operations
                color: 205 65 58
                links:
                  - { title: Tailscale Admin, url: "https://login.tailscale.com/admin/machines", description: "Machines, routes, key expiry", icon: "di:tailscale" }
                  - { title: Cloudflare Zero Trust, url: "https://one.dash.cloudflare.com/", description: "Home Assistant tunnel", icon: "di:cloudflare" }
                  - { title: GitHub Repo, url: "https://github.com/osmondsimon-bit/homelab", description: "Infrastructure code and docs", icon: "di:github-light" }
                  - { title: Dependency Updates, url: "https://github.com/osmondsimon-bit/homelab/issues?q=is%3Aissue%20is%3Aopen%20%22Dependency%20Dashboard%22", description: "Renovate proposals", icon: "di:renovate" }
              - title: Tailnet-only
                color: 48 70 50
                links:
                  - { title: Vaultwarden, url: "<< vaultwarden_domain >>", description: "Password vault", icon: "di:vaultwarden" }
                  <% if actual_enabled | default(false) %>
                  - { title: Actual Budget, url: "<< actual_domain >>", description: "Personal finance", icon: "di:actual-budget" }
                  <% endif %>

  # Deeper resource and placement surface. Grafana remains the time-series/debugging destination.
  - name: Infrastructure
    width: wide
    columns:
      - size: full
        widgets:
          - type: custom-api
            title: Proxmox Hosts
            cache: 30s
            url: << prom >>
            parameters:
              query: instance:node_cpu_util:percent{instance=~`<< glance_host_instances >>`}
            subrequests:
              cpu_peak:
                url: << prom >>
                parameters:
                  query: max_over_time(instance:node_cpu_util:percent{instance=~`<< glance_host_instances >>`}[24h:5m])
              ram:
                url: << prom >>
                parameters:
                  query: instance:node_mem_util:percent{instance=~`<< glance_host_instances >>`}
              ram_peak:
                url: << prom >>
                parameters:
                  query: max_over_time(instance:node_mem_util:percent{instance=~`<< glance_host_instances >>`}[24h:5m])
              storage:
                url: << prom >>
                parameters:
                  query: 100 * max by(node) (label_replace(pve_disk_usage_bytes{id=~"storage/.*/local-zfs"} / pve_disk_size_bytes{id=~"storage/.*/local-zfs"}, "node", "$1", "id", "storage/([^/]+)/local-zfs"))
              updates:
                url: << prom >>
                parameters:
                  query: clamp_min(homelab_apt_upgrades_pending{kind="pve-host"} - ignoring(policy) homelab_apt_security_upgrades_pending{kind="pve-host"}, 0)
              security:
                url: << prom >>
                parameters:
                  query: homelab_apt_security_upgrades_pending{kind="pve-host"}
              reboot:
                url: << prom >>
                parameters:
                  query: homelab_reboot_required{kind="pve-host"}
            template: |
              {{ $cpuPeak := .Subrequest "cpu_peak" }}{{ $ram := .Subrequest "ram" }}{{ $ramPeak := .Subrequest "ram_peak" }}{{ $storage := .Subrequest "storage" }}{{ $updates := .Subrequest "updates" }}{{ $security := .Subrequest "security" }}{{ $reboot := .Subrequest "reboot" }}
              <div class="host-grid">
              <% for h in glance_hosts %>
                {{ $cpu := 0.0 }}{{ range $.JSON.Array "data.result" }}{{ if eq (.String "metric.instance") "<< h.node_exporter_instance >>" }}{{ $cpu = .Float "value.1" }}{{ end }}{{ end }}
                {{ $cpuP := 0.0 }}{{ range $cpuPeak.JSON.Array "data.result" }}{{ if eq (.String "metric.instance") "<< h.node_exporter_instance >>" }}{{ $cpuP = .Float "value.1" }}{{ end }}{{ end }}
                {{ $ramN := 0.0 }}{{ range $ram.JSON.Array "data.result" }}{{ if eq (.String "metric.instance") "<< h.node_exporter_instance >>" }}{{ $ramN = .Float "value.1" }}{{ end }}{{ end }}
                {{ $ramP := 0.0 }}{{ range $ramPeak.JSON.Array "data.result" }}{{ if eq (.String "metric.instance") "<< h.node_exporter_instance >>" }}{{ $ramP = .Float "value.1" }}{{ end }}{{ end }}
                {{ $disk := 0.0 }}{{ range $storage.JSON.Array "data.result" }}{{ if eq (.String "metric.node") "<< h.name >>" }}{{ $disk = .Float "value.1" }}{{ end }}{{ end }}
                {{ $pending := 0.0 }}{{ range $updates.JSON.Array "data.result" }}{{ if eq (.String "metric.target") "<< h.name >>" }}{{ $pending = .Float "value.1" }}{{ end }}{{ end }}
                {{ $securityN := 0.0 }}{{ range $security.JSON.Array "data.result" }}{{ if eq (.String "metric.target") "<< h.name >>" }}{{ $securityN = .Float "value.1" }}{{ end }}{{ end }}
                {{ $rebootN := 0.0 }}{{ range $reboot.JSON.Array "data.result" }}{{ if eq (.String "metric.target") "<< h.name >>" }}{{ $rebootN = .Float "value.1" }}{{ end }}{{ end }}
                <div class="host-card">
                  <div class="flex justify-between gap-10"><div class="color-highlight size-h3"><< h.name >></div><div class="{{ if or (gt $securityN 0.0) (gt $rebootN 0.0) }}color-negative{{ else }}color-positive{{ end }}">{{ if or (gt $securityN 0.0) (gt $rebootN 0.0) }}Attention{{ else }}Healthy{{ end }}</div></div>
                  <div class="resource-row"><div class="resource-heading"><div class="resource-label">CPU</div><div>{{ printf "%.1f%%" $cpu }}</div></div><meter class="resource-meter {{ if ge $cpu 90.0 }}is-critical{{ else if ge $cpu 75.0 }}is-warning{{ end }}" min="0" max="100" low="75" high="90" optimum="0" value="{{ $cpu }}"></meter><div class="resource-reading"><span>now</span><span>{{ printf "%.1f%% 24h peak" $cpuP }}</span></div></div>
                  <div class="resource-row"><div class="resource-heading"><div class="resource-label">RAM</div><div>{{ printf "%.1f%%" $ramN }}</div></div><meter class="resource-meter {{ if ge $ramN 90.0 }}is-critical{{ else if ge $ramN 75.0 }}is-warning{{ end }}" min="0" max="100" low="75" high="90" optimum="0" value="{{ $ramN }}"></meter><div class="resource-reading"><span>now</span><span>{{ printf "%.1f%% 24h peak" $ramP }}</span></div></div>
                  <div class="resource-row"><div class="resource-heading"><div class="resource-label">Local ZFS</div><div>{{ printf "%.1f%%" $disk }}</div></div><meter class="resource-meter {{ if ge $disk 85.0 }}is-critical{{ else if ge $disk 70.0 }}is-warning{{ end }}" min="0" max="100" low="70" high="85" optimum="0" value="{{ $disk }}"></meter></div>
                  <div class="size-h6 color-subdue margin-top-10">{{ printf "%.0f monthly updates · %.0f security manual · %.0f reboot" $pending $securityN $rebootN }}</div>
                </div>
              <% endfor %>
              </div>

          - type: custom-api
            title: Workloads by Host
            cache: 30s
            url: << prom >>
            parameters:
              query: sort_desc(max without(resource) (label_replace(guest:pve_cpu_util:percent{id!="qemu/128"}, "resource", "cpu", "__name__", ".*") or label_replace(guest:pve_mem_util:percent{id!="qemu/128"}, "resource", "ram", "__name__", ".*") or label_replace(max by(id,name,node,type) (((pve_disk_usage_bytes{id=~"lxc/.*|qemu/.*",id!="qemu/128"} / pve_disk_size_bytes{id=~"lxc/.*|qemu/.*",id!="qemu/128"}) * 100) * on(id,instance,job) group_left(name,node,type) pve_guest_info), "resource", "disk", "__name__", ".*")))
            subrequests:
              cpu:
                url: << prom >>
                parameters:
                  query: guest:pve_cpu_util:percent{id!="qemu/128"}
              cpu_peak:
                url: << prom >>
                parameters:
                  query: max by(id) (max_over_time(guest:pve_cpu_util:percent{id!="qemu/128"}[24h:5m]))
              ram:
                url: << prom >>
                parameters:
                  query: guest:pve_mem_util:percent{id!="qemu/128"}
              ram_peak:
                url: << prom >>
                parameters:
                  query: max by(id) (max_over_time(guest:pve_mem_util:percent{id!="qemu/128"}[24h:5m]))
              disk:
                url: << prom >>
                parameters:
                  query: max by(id,name,node,type) (((pve_disk_usage_bytes{id=~"lxc/.*|qemu/.*",id!="qemu/128"} / pve_disk_size_bytes{id=~"lxc/.*|qemu/.*",id!="qemu/128"}) * 100) * on(id,instance,job) group_left(name,node,type) pve_guest_info)
            template: |
              {{ $cpuResult := .Subrequest "cpu" }}{{ $cpuPeak := .Subrequest "cpu_peak" }}{{ $ramResult := .Subrequest "ram" }}{{ $ramPeak := .Subrequest "ram_peak" }}{{ $diskResult := .Subrequest "disk" }}
              <div>
                <div class="workload-note">VM guest filesystem usage is not collected; a dash in Disk means unavailable.</div>
              <% for h in glance_hosts %>
                <section class="workload-host">
                  <div class="color-highlight size-h3"><< h.name >></div>
                  <div class="workload-rows collapsible-container" data-collapse-after="5">
                  {{ range $.JSON.Array "data.result" }}{{ if eq (.String "metric.node") "<< h.name >>" }}
                    {{ $id := .String "metric.id" }}{{ $guestType := .String "metric.type" }}{{ $score := .Float "value.1" }}
                    {{ $cpu := 0.0 }}{{ range $cpuResult.JSON.Array "data.result" }}{{ if eq (.String "metric.id") $id }}{{ $cpu = .Float "value.1" }}{{ end }}{{ end }}
                    {{ $cpuP := 0.0 }}{{ range $cpuPeak.JSON.Array "data.result" }}{{ if eq (.String "metric.id") $id }}{{ $cpuP = .Float "value.1" }}{{ end }}{{ end }}
                    {{ $ram := 0.0 }}{{ range $ramResult.JSON.Array "data.result" }}{{ if eq (.String "metric.id") $id }}{{ $ram = .Float "value.1" }}{{ end }}{{ end }}
                    {{ $ramP := 0.0 }}{{ range $ramPeak.JSON.Array "data.result" }}{{ if eq (.String "metric.id") $id }}{{ $ramP = .Float "value.1" }}{{ end }}{{ end }}
                    {{ $disk := 0.0 }}{{ $diskFound := false }}{{ range $diskResult.JSON.Array "data.result" }}{{ if and (ne $guestType "qemu") (eq (.String "metric.id") $id) }}{{ $disk = .Float "value.1" }}{{ $diskFound = true }}{{ end }}{{ end }}
                    <div class="workload-row {{ if ge $score 90.0 }}color-negative{{ end }}">
                      <div class="workload-identity"><div class="color-highlight text-truncate">{{ .String "metric.name" }}</div><div class="placement-label">{{ $id }} · highest resource {{ printf "%.0f%%" $score }}</div></div>
                      <div class="workload-metric"><div class="resource-heading"><div class="resource-label">CPU</div><div>{{ if and (gt $cpu 0.0) (lt $cpu 1.0) }}&lt;1%{{ else }}{{ printf "%.0f%%" $cpu }}{{ end }}</div></div><meter class="resource-meter {{ if ge $cpu 90.0 }}is-critical{{ else if ge $cpu 75.0 }}is-warning{{ end }}" min="0" max="100" low="75" high="90" optimum="0" value="{{ $cpu }}"></meter><div class="placement-label">peak {{ if and (gt $cpuP 0.0) (lt $cpuP 1.0) }}&lt;1%{{ else }}{{ printf "%.0f%%" $cpuP }}{{ end }}</div></div>
                      <div class="workload-metric"><div class="resource-heading"><div class="resource-label">RAM</div><div>{{ printf "%.0f%%" $ram }}</div></div><meter class="resource-meter {{ if ge $ram 90.0 }}is-critical{{ else if ge $ram 75.0 }}is-warning{{ end }}" min="0" max="100" low="75" high="90" optimum="0" value="{{ $ram }}"></meter><div class="placement-label">peak {{ printf "%.0f%%" $ramP }}</div></div>
                      <div class="workload-metric"><div class="resource-heading"><div class="resource-label">Disk</div><div>{{ if $diskFound }}{{ printf "%.0f%%" $disk }}{{ else }}&mdash;{{ end }}</div></div>{{ if $diskFound }}<meter class="resource-meter {{ if ge $disk 85.0 }}is-critical{{ else if ge $disk 70.0 }}is-warning{{ end }}" min="0" max="100" low="70" high="85" optimum="0" value="{{ $disk }}"></meter>{{ else }}<div class="resource-meter-spacer" aria-hidden="true"></div>{{ end }}</div>
                    </div>
                  {{ end }}{{ end }}
                  </div>
                </section>
              <% endfor %>
              </div>

      - size: small
        widgets:
          - type: custom-api
            title: Fleet Baseline
            cache: 5m
            url: << prom >>
            parameters:
              query: pve_version_info
            subrequests:
              prometheus:
                url: << prom >>
                parameters:
                  query: prometheus_build_info
              os:
                url: << prom >>
                parameters:
                  query: node_os_info
            template: |
              {{ $os := .Subrequest "os" }}{{ $prom := .Subrequest "prometheus" }}
              <div class="list list-gap-10">
              <% for h in glance_hosts %>
                <div><div class="color-highlight"><< h.name >></div><div class="size-h6 color-subdue">PVE {{ range $.JSON.Array "data.result" }}{{ if eq (.String "metric.job") "pve-<< h.name >>" }}{{ .String "metric.version" }}{{ end }}{{ end }} · {{ range $os.JSON.Array "data.result" }}{{ if eq (.String "metric.instance") "<< h.node_exporter_instance >>" }}{{ .String "metric.name" }} {{ .String "metric.version_id" }}{{ end }}{{ end }}</div></div>
              <% endfor %>
                <hr class="margin-block-5">
                <div class="flex justify-between gap-10"><div class="color-highlight">Prometheus</div><div>{{ range $prom.JSON.Array "data.result" }}{{ .String "metric.version" }}{{ end }}</div></div>
                <div class="size-h6 color-subdue">Package-managed currency is represented by Maintenance State. Jellyfin, qBittorrent and native Servarr runtime versions are not collected.</div>
              </div>

          - type: releases
            title: Latest Releases
            cache: 12h
            limit: 8
            collapse-after: 5
            show-source-icon: true
            repositories:
              <% for r in glance_release_repos %>
              - << r >>
              <% endfor %>
